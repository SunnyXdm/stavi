{
  "name": "stavi",
  "version": "0.1.0",
  "description": "Mobile IDE for AI coding agents — server CLI",
  "private": false,
  "type": "module",
  "bin": {
    "stavi": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "sh -c 'bun --watch src/index.ts serve --port ${STAVI_PORT:-3773} --host ${STAVI_HOST:-0.0.0.0} ${STAVI_PROJECT_ROOT:-.}'",
    "build": "bun build src/index.ts --outfile dist/index.mjs --target node --format esm",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stavi/crypto": "*",
    "@stavi/server-core": "*",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.14",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
