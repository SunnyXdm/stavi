{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@stavi/server-core": ["../../packages/server-core/src"],
      "@stavi/server-core/*": ["../../packages/server-core/src/*"],
      "@stavi/crypto": ["../../packages/crypto/src"],
      "@stavi/crypto/*": ["../../packages/crypto/src/*"],
      "@stavi/shared": ["../../packages/shared/src"],
      "@stavi/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src"]
}
